# docker-compose top-level variables.
# Copy to `.env` (same folder as docker-compose.yml) and adjust per environment.

# FE build-time API URLs (baked into the bundles at `docker compose build`)
# Local dev: http://localhost:5000
# Production: https://<your-prod-domain>
ALHC_VITE_API_URL=http://localhost:5000
WEB_VITE_API_URL=http://localhost:5000

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=loyalty
